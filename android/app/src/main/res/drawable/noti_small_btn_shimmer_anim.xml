<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">

    <!-- Shimmer sweep: left to right -->
    <item android:drawable="@drawable/noti_small_btn_shimmer_0" android:duration="150" />
    <item android:drawable="@drawable/noti_small_btn_shimmer_1" android:duration="150" />
    <item android:drawable="@drawable/noti_small_btn_shimmer_2" android:duration="150" />
    <item android:drawable="@drawable/noti_small_btn_shimmer_3" android:duration="150" />
    <item android:drawable="@drawable/noti_small_btn_shimmer_4" android:duration="150" />

    <!-- Rest pause -->
    <item android:drawable="@drawable/noti_small_btn" android:duration="200" />
    <item android:drawable="@drawable/noti_small_btn" android:duration="200" />
    <item android:drawable="@drawable/noti_small_btn" android:duration="200" />
    <item android:drawable="@drawable/noti_small_btn" android:duration="200" />

</animation-list>
