<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="160dp"
    android:layout_height="170dp"
    android:background="@drawable/widget_bg_dark_rounded"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Top Part: Icon and Intake Numbers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp">

            <ImageView
                android:id="@+id/iv_progress_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:contentDescription="Progress Ring" />

            <ImageView
                android:id="@+id/iv_water_drop"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:translationY="-4dp"
                android:src="@drawable/img_water"
                android:contentDescription="Water" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="0dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_current_ml"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/clr_white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="normal" />

                <TextView
                    android:id="@+id/tv_goal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-2dp"
                    android:text="/ 2000 ml"
                    android:textColor="@color/clr_text_muted"
                    android:textSize="10sp"
                    android:textStyle="normal" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Bottom Row: Add Drink (start) and Cup Icon (end) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingBottom="0dp">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:background="@drawable/widget_btn_container_border"
            android:padding="2dp">

            <TextView
                android:id="@+id/btn_add_drink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_btn_gradient"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="@string/add_drink"
                android:textColor="@color/clr_white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="normal" />
        </FrameLayout>

        
    </RelativeLayout>

</LinearLayout>
