<?xml version="1.0" encoding="utf-8"?>
<!-- Large Widget: Progress bar + drink history + quick add buttons -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_bg_dark_rounded"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Percentage + progress bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="90%"
            android:textColor="@color/clr_white"
            android:textSize="36sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="90"
            android:progressDrawable="@drawable/widget_progress_bar" />
    </LinearLayout>

    <!-- Intake text -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_label_today_intake"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="@string/today_s_intake"
            android:textColor="@color/clr_white"
            android:textStyle="normal"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_current_ml"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1800ml"
            android:textColor="@color/clr_white"
            android:textSize="12sp"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/tv_goal_ml"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" / 2000ml"
            android:textColor="@color/clr_text_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1" />
    <!-- Goal status (shown when goal reached or exceeded) -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/widget_cyan"
        android:textSize="12sp"
        android:textStyle="normal"
        android:visibility="gone" />

    <!-- No history placeholder -->
    <TextView
        android:id="@+id/tv_no_history"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/no_records_today"
        android:textColor="@color/clr_text_muted"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Drink history: Milk -->
    <LinearLayout
        android:id="@+id/row_drink_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_drink_1_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_water_drop"
            android:contentDescription="Drink type" />

        <TextView
            android:id="@+id/tv_drink_1_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Milk"
            android:textColor="@color/clr_white"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_drink_1_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="456 ml"
            android:textColor="@color/widget_cyan"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_drink_1_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_history_time_bg"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="08:00 AM"
            android:textColor="@color/clr_white"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Drink history: Water -->
    <LinearLayout
        android:id="@+id/row_drink_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_drink_2_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_water_drop"
            android:contentDescription="Drink type" />

        <TextView
            android:id="@+id/tv_drink_2_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Water"
            android:textColor="@color/clr_white"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_drink_2_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="660 ml"
            android:textColor="@color/widget_cyan"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_drink_2_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_history_time_bg"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="06:00 AM"
            android:textColor="@color/clr_white"
            android:textSize="11sp" />
    </LinearLayout>
    <!--  -->

    <!-- Quick add buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_150"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_quick_add_bg"
                android:drawableTop="@drawable/ic_water_capacity_150"
                android:drawablePadding="0dp"
                android:gravity="center"
                android:paddingTop="4dp"
                android:text="150 ml"
                android:textColor="@color/clr_white"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/btn_200"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_quick_add_bg"
                android:drawableTop="@drawable/ic_water_capacity_200"
                android:drawablePadding="0dp"
                android:gravity="center"
                android:paddingTop="4dp"
                android:text="200 ml"
                android:textColor="@color/clr_white"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/btn_300"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/widget_quick_add_bg"
                android:drawableTop="@drawable/ic_water_capacity_300"
                android:drawablePadding="0dp"
                android:gravity="center"
                android:paddingTop="4dp"
                android:text="300 ml"
                android:textColor="@color/clr_white"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_500"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_quick_add_bg"
                android:drawableTop="@drawable/ic_water_capacity_500"
                android:drawablePadding="0dp"
                android:gravity="center"
                android:paddingTop="4dp"
                android:text="500 ml"
                android:textColor="@color/clr_white"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/btn_700"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_quick_add_bg"
                android:drawableTop="@drawable/ic_water_capacity_700"
                android:drawablePadding="0dp"
                android:gravity="center"
                android:paddingTop="4dp"
                android:text="700 ml"
                android:textColor="@color/clr_white"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/btn_custom"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/widget_quick_add_bg"
                android:drawableTop="@drawable/ic_edit_water"
                android:drawablePadding="0dp"
                android:gravity="center"
                android:paddingTop="4dp"
                android:text="@string/custom"
                android:textColor="@color/clr_white"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
